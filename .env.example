# Copy this file to .env (it will be loaded by Next.js and Prisma)
#
# When running with Docker Compose, the hostname is "db" (the service name)
# and the port stays 5432 (internal container port).
#
# When running Next.js locally (npm run dev) but Postgres in Docker,
# use "localhost:5433" — the host machine sees Postgres on 5433
# (5432 is often already taken on the host).
DATABASE_URL="postgresql://student:student@db:5432/learn?schema=public"
